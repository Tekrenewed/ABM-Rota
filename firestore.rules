rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow the client app to read/write staff and settings for management
    match /staff/{staffId} {
      allow read, write: if true;
    }
    match /settings/{docId} {
      allow read, write: if true;
    }
    match /rotas/{docId} {
      allow read, write: if true;
    }
    // Allow shifts to be created and read freely
    match /shifts/{shiftId} {
      allow read, write: if true;
    }
  }
}
